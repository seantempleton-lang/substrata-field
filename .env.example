PORT=3002
HOST=0.0.0.0

# Preferred: paste the full Coolify PostgreSQL connection string here.
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/substrata_field

# Optional if you do not use DATABASE_URL:
# PGHOST=postgres
# PGPORT=5432
# PGDATABASE=substrata_field
# PGUSER=postgres
# PGPASSWORD=change-me
# PGSSLMODE=disable

# Automatically create tables and seed from api-data.json if the DB is empty.
SUBSTRATA_SEED_DB=true

# Optional custom seed file path.
# SUBSTRATA_API_DATA=/app/api-data.json
