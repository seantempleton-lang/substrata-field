PORT=3000
HOST=0.0.0.0

# Preferred: paste the full Coolify PostgreSQL connection string here.
# This should point at the separate SubStrata-Field database. Field creates
# its own auth tables using the same basic structure as SubStrata-OpsManager.
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/substrata_field

# Optional if you do not use DATABASE_URL:
# PGHOST=postgres
# PGPORT=5432
# PGDATABASE=substrata_field
# PGUSER=postgres
# PGPASSWORD=change-me
# PGSSLMODE=disable

# Automatically create tables and seed from api-data.json if the DB is empty.
SUBSTRATA_SEED_DB=true

# Optional custom seed file path.
# SUBSTRATA_API_DATA=/app/api-data.json

# CORE-GS MSSQL bridge. Set CORE_GS_ENABLED=true once the connection details
# have been confirmed from the Coolify host to the CORE-GS SQL Server.
CORE_GS_ENABLED=false
CORE_GS_HOST=192.168.1.50
CORE_GS_INSTANCE=SQLSTANDARD2019
# Fixed TCP port for SQLSTANDARD2019.
CORE_GS_PORT=1435
CORE_GS_DATABASE=CORE-GS-TEST
CORE_GS_USER=api.qgis
CORE_GS_PASSWORD=change-me
CORE_GS_ENCRYPT=false
CORE_GS_TRUST_SERVER_CERTIFICATE=true
CORE_GS_CLNT_ID=Geotechnical
